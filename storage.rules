rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isEditor() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
           in ['admin', 'editor'];
    }

    // Imagenes del club — solo editor/admin sube, lectura publica
    match /clubs/{clubId}/{allPaths=**} {
      allow read: if true;
      allow write: if isEditor();
    }
  }
}
